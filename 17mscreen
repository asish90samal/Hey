"""
cli/screen.py
─────────────
Command-line entry point for the AML screener.

This file's ONLY responsibilities:
  1. Parse CLI arguments
  2. Build the infrastructure by calling the proper layers
  3. Call IntegratedScreeningOrchestrator.screen_integrated() per person
  4. Print the per-person comparison display
  5. Print the batch summary and optional model report

Every piece of business logic lives in its proper layer:
  Data loading    → data_layer/registry/dataset_registry.py
  Blocking        → blocking_engine/inverted_index.py
  Rule matching   → matching_engine/rules/
  ML scoring      → ml_engine/model.py          (AMLModel)
  Graph risk      → graph_engine/graph.py
  Blending        → scoring/consolidator.py     (blend())
  Policy          → policy_engine/thresholds.py
  Orchestration   → orchestration/orchestrator.py (IntegratedScreeningOrchestrator)

Usage
─────
  # Single name
  python -m cli.screen --name "Mohammed Ali Hassan" --country IRAN --dob 1970-03-15

  # Multiple names
  python -m cli.screen --names "Virat Kohli, John Smith, Alexei Volkov"

  # CSV file  (columns: name, country, dob, entity_type, job_type)
  python -m cli.screen --csv customers.csv

  # Full ML accuracy report
  python -m cli.screen --csv customers.csv --model-report
"""
from __future__ import annotations
import argparse, os, sys, textwrap, time
import pandas as pd

ROOT = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
if ROOT not in sys.path:
    sys.path.insert(0, ROOT)

# ── Display constants ─────────────────────────────────────────────────────────
W     = 50
BOLD  = "\033[1m";  GRAY  = "\033[90m"; RESET = "\033[0m"
RED   = "\033[91m"; YEL   = "\033[93m"; GRN   = "\033[92m"; CYN   = "\033[96m"

def _p(s, w=W): return str(s)[:w].ljust(w)
def _row(l, r): print(f"  {_p(l)} | {_p(r)}")
def _div(c="-"): print(f"  {c*W} | {c*W}")
def _col(s, c): return f"{c}{s}{RESET}"
def _bar(v, w=16): n = int(round(v * w)); return "#" * n + "-" * (w - n)
def _dec(d, score):
    c = RED if d == "ALERT" else YEL if d == "REVIEW" else GRN
    return _col(f"{d}  ({score:.4f})", c)


# ── Infrastructure builder ────────────────────────────────────────────────────

def build_infrastructure(verbose=True):
    """
    Initialise every layer in dependency order.
    Returns the IntegratedScreeningOrchestrator ready to call .screen_integrated().
    """
    import pandas as pd
    from data_layer.registry.dataset_registry import DatasetRegistry
    from blocking_engine.inverted_index import MultiDatasetIndex
    from matching_engine.rules.base_rule import MatchingRuleEngine
    from graph_engine.graph import build_graph, propagate_risk
    from ml_engine.model import AMLModel
    from orchestration.orchestrator import IntegratedScreeningOrchestrator

    if verbose:
        print("\n" + "=" * 55)
        print("  AML ENTERPRISE SCREENER  |  Initialising")
        print("=" * 55)

    # 1. Data layer
    registry = DatasetRegistry()
    registry.load_all(verbose=verbose)

    # 2. Blocking / index layer
    if verbose: print("  Inverted index          ...", end=" ", flush=True)
    t = time.perf_counter()
    idx = MultiDatasetIndex()
    idx.build_from_registry(registry, verbose=False)
    if verbose: print(f"done  {(time.perf_counter()-t)*1000:.0f} ms")

    # 3. Matching rule engine
    rule_engine = MatchingRuleEngine(use_llm=False)

    # 4. Graph layer
    if verbose: print("  Graph engine            ...", end=" ", flush=True)
    t = time.perf_counter()
    combined = pd.concat(list(registry._store.values()), ignore_index=True)
    G = build_graph(combined, add_country_edges=True, add_alias_edges=True,
                    add_id_prefix_edges=False)
    G = propagate_risk(G, iterations=3, damping=0.15)
    if verbose: print(f"done  {G.number_of_nodes()} nodes  {(time.perf_counter()-t)*1000:.0f} ms")

    # 5. ML layer
    if verbose: print("  ML model                ...", end=" ", flush=True)
    t = time.perf_counter()
    model = AMLModel()
    X, y  = AMLModel.build_training_data(registry)
    model.train(X, y)
    if verbose: print(f"done  {(time.perf_counter()-t)*1000:.0f} ms")

    if verbose: print("=" * 55 + "\n")

    # 6. Orchestration layer
    return IntegratedScreeningOrchestrator(
        registry=registry,
        multi_index=idx,
        rule_engine=rule_engine,
        ml_model=model,
        graph=G,
    ), model


