def _hit_dec_col(h):
    if h.auto_alert:  return RED
    if h.review_flag: return YEL
    return GRAY


def _rule_flow_diagram(all_rule_scores: dict, winning_code: str, job_code: str):
    """
    Print a full rule-by-rule flow diagram for one hit.

    For every OWS rule shows:
      [FIRED]   code  label          score  bar       ← rule scored > 0
      [ZERO ]   code  label          0.000  ---       ← rule ran but scored 0
      [OFF  ]   code  label          --     disabled  ← rule disabled for this job

    The winning rule is highlighted with >>>
    """
    from config.rule_config import get_rule_config

    cfg = get_rule_config(job_code)

    # Full ordered rule list with their config keys
    RULE_DEFS = [
        ("I010O", "Exact name match",         "I010O_EXACT"),
        ("I020O", "Fuzzy composite",           "I020O_FUZZY"),
        ("I030O", "Reversed token order",      "I030O_REVERSED"),
        ("I040O", "Given/family split",        "I040O_GIVEN_FAMILY"),
        ("I050O", "Abbreviated given name",    "I050O_ABBREVIATED"),
        ("I060O", "Phonetic (metaphone)",      "I060O_PHONETIC"),
        ("I070O", "Transliteration",           "I070O_TRANSLITERATION"),
        ("I080O", "DOB cluster",               "I080O_DOB_CLUSTER"),
    ]

    print(f"  {'':3} {'Rule':<7} {'Label':<24} {'Score':>6}  {'Bar':<16}  Status")
    print(f"  {'─'*3} {'─'*7} {'─'*24} {'─'*6}  {'─'*16}  {'─'*10}")

    for code, label, cfg_key in RULE_DEFS:
        is_winner  = (code == winning_code)
        is_enabled = cfg.enabled(cfg_key)
        score      = all_rule_scores.get(code, 0.0) if is_enabled else None

        prefix = ">>>" if is_winner else "   "

        if not is_enabled:
            status = _col("OFF (disabled)", GRAY)
            bar_s  = _col("─" * 16, GRAY)
            sc_s   = _col("  --  ", GRAY)
        elif score is None or score == 0.0:
            status = _col("ZERO (no match)", GRAY)
            bar_s  = _col("░" * 16, GRAY)
            sc_s   = _col(" 0.000", GRAY)
        else:
            if   score >= 0.65: sc_col = RED
            elif score >= 0.57: sc_col = YEL
            elif score >= 0.30: sc_col = GRN
            else:               sc_col = GRAY
            bar_s  = _col(_bar(score), sc_col)
            sc_s   = _col(f"{score:6.3f}", sc_col)
            status = _col("FIRED ✓", GRN) if not is_winner else _col("FIRED ✓  WINNER", BOLD)

        pfx_col = _col(prefix, BOLD if is_winner else GRAY)
        print(f"  {pfx_col} {code:<7} {label:<24} {sc_s}  [{bar_s}]  {status}")


def print_comparison(out, num: int, total: int):
    """
    Side-by-side comparison for one IntegratedOutput.

    Layout
    ──────
    Header      : person info, job code, country, DOB
    Section 1   : Diagrammatic hit table — per dataset, per hit,
                  with full rule flow diagram (every rule: fired/zero/off)
    Section 2   : Score arithmetic — rule / ML / graph / blend
    Section 3   : Decision + warnings
    """
    from policy_engine.thresholds import apply_threshold
    from collections import defaultdict

    FULL = W * 2 + 5
    bar  = "=" * FULL

    # ── Header ───────────────────────────────────────────────────────────────
    print(f"\n{bar}")
    print(f"  PERSON {num}/{total}  --  {_col(out.input.name, BOLD)}")
    print(bar)
    _row(_col("  WITHOUT INTEGRATION", BOLD),
         _col("  WITH INTEGRATION", BOLD))
    _row(_col("  (rule-based only)", GRAY),
         _col("  (rule 50% + ML 30% + graph 20%)", GRAY))
    _div()

    country = out.input.country or out.input.nationality or "N/A"
    dob     = out.input.dob or "N/A"
    _row(f"  Country    : {country}",     f"  Country    : {country}")
    _row(f"  DOB        : {dob}",         f"  DOB        : {dob}")
    _row(f"  Job code   : {out.job_code}", f"  Job code   : {out.job_code}")

    # ── Section 1: Hit breakdown ──────────────────────────────────────────────
    cr     = out.consolidated
    hits   = cr.hits if cr else []
    n_hits = len(hits)

    _div(".")
    print(f"  {_col('HIT BREAKDOWN', BOLD)}  "
          f"({n_hits} match{'es' if n_hits != 1 else ''} above 0.30 threshold)")

    if not hits:
        _div(".")
        print(_col("  No matches found above threshold.", GRAY))
    else:
        # Group by dataset, sort datasets best-first
        by_ds: dict[str, list] = defaultdict(list)
        for h in hits:
            by_ds[h.dataset_code].append(h)

        sorted_ds = sorted(by_ds.keys(),
                           key=lambda d: max(h.rule_score for h in by_ds[d]),
                           reverse=True)

        for ds_code in sorted_ds:
            ds_hits  = sorted(by_ds[ds_code], key=lambda h: -h.rule_score)
            best_ds  = ds_hits[0].rule_score
            ds_col   = RED if best_ds >= 0.65 else YEL if best_ds >= 0.57 else GRAY

            # ── Dataset header ────────────────────────────────────────────
            _div(".")
            print(f"  {_col('DATASET', BOLD)} : {_col(ds_code, CYN)}  "
                  f"best={_col(f'{best_ds:.3f}', ds_col)} [{_bar(best_ds, 10)}]  "
                  f"({len(ds_hits)} hit{'s' if len(ds_hits)>1 else ''})")

            for rank, h in enumerate(ds_hits, 1):
                dc = _hit_dec_col(h)

                # Name line
                _div(".")
                alias_note = ""
                if h.matched_on_alias and h.matched_name != h.primary_name:
                    alias_note = f"  {_col(f'(alias: {h.matched_name})', GRAY)}"

                flags = []
                if h.auto_alert:       flags.append(_col("AUTO-ALERT", RED))
                if h.review_flag:      flags.append(_col("REVIEW-FLAG", YEL))
                flags_str = "  " + "  ".join(flags) if flags else ""

                print(f"  {_col(f'#{rank}', BOLD)} {_col(h.primary_name, BOLD)}"
                      f"{alias_note}{flags_str}")
                print(f"     Score : {_col(f'{h.rule_score:.4f}', dc)}"
                      f"  [{_bar(h.rule_score)}]"
                      f"  Winner : {_col(h.rule_code, BOLD)} "
                      f"{_RULE_LABELS.get(h.rule_code, h.rule_code)}")

                # ── Rule flow diagram ─────────────────────────────────────
                if h.all_rule_scores:
                    print()
                    _rule_flow_diagram(h.all_rule_scores, h.rule_code, out.job_code)

                # Only show flow for top 5 per dataset to keep output manageable
                if rank >= 5:
                    remaining = len(ds_hits) - rank
                    if remaining > 0:
                        print(_col(f"     ... {remaining} more hit(s) not shown", GRAY))
                    break

    # ── Section 2: Score arithmetic ──────────────────────────────────────────
    rs = out.rule_score
    ms = out.ml_score
    gs = out.graph_risk
    bs = out.blended_score

    _div(".")
    _row("  Score components:", "  Score components:")
    _row(f"  Rule score  : {rs:.4f}  [{_bar(rs)}]",
         f"  Rule  {rs:.4f} x 0.50 = {rs*0.50:.4f}")
    ml_str = f"{ms:.4f} x 0.30 = {ms*0.30:.4f}" if ms is not None else "N/A (no hit)"
    gs_str = f"{gs:.4f} x 0.20 = {gs*0.20:.4f}" if gs is not None else "N/A (no hit)"
    _row("  ML score    : not computed",  f"  ML    {ml_str}")
    _row("  Graph risk  : not computed",  f"  Graph {gs_str}")
    _div("-")
    _row(f"  FINAL SCORE : {rs:.4f}  (rule only)",
         f"  FINAL SCORE : {bs:.4f}  (blended)")
    _div("-")

    rule_dec = apply_threshold(rs, out.job_code).decision
    _row(f"  DECISION : {_dec(rule_dec, rs)}",
         f"  DECISION : {_dec(out.overall_decision, bs)}")

    # ── Section 3: Warnings ───────────────────────────────────────────────────
    if out.fp_flag:
        _div("!")
        print(_col("  [!] POSSIBLE FALSE POSITIVE", YEL))
        for part in out.fp_reason.split(";"):
            p = part.strip()
            if p:
                print(_col(f"      * {p}", YEL))
        print(_col("  Recommend manual review before raising an alert.", YEL))

    if rule_dec != out.overall_decision:
        _div("!")
        diff      = bs - rs
        direction = f"UP +{diff:.4f}" if diff > 0 else f"DOWN {diff:.4f}"
        print(_col(
            f"  [!] INTEGRATION CHANGED DECISION: "
            f"{rule_dec} -> {out.overall_decision}  ({direction})", YEL))

    _row(f"  Latency : {out.latency_ms:.1f} ms",
         f"  Latency : {out.latency_ms:.1f} ms (shared)")


# ── Batch summary ─────────────────────────────────────────────────────────────

def print_batch_summary(outputs: list):
    from policy_engine.thresholds import apply_threshold
    bar = "=" * 105
    print(f"\n{bar}")
    print("  BATCH SUMMARY")
    print(bar)
    print(f"  {'#':<3} {'Name':<28} {'Rule':>7} {'Rule Dec':<10} {'Blended':>8} {'Int Dec':<10} {'Changed':<8} {'FP?'}")
    print(f"  {'-'*100}")

    for i, out in enumerate(outputs, 1):
        rs       = out.rule_score
        bs       = out.blended_score
        rule_dec = apply_threshold(rs, out.job_code).decision
        int_dec  = out.overall_decision
        cr       = RED if rule_dec == "ALERT" else YEL if rule_dec == "REVIEW" else GRN
        ci       = RED if int_dec  == "ALERT" else YEL if int_dec  == "REVIEW" else GRN
        chg      = _col("YES", YEL) if rule_dec != int_dec else "   "
        fp       = _col("[!]", YEL) if out.fp_flag else "   "
        print(f"  {i:<3} {out.input.name[:28]:<28} {rs:>7.4f} {_col(rule_dec,cr):<10} "
              f"{bs:>8.4f} {_col(int_dec,ci):<10} {chg}  {fp}")

    print()
    n    = len(outputs)
    from policy_engine.thresholds import apply_threshold as at
    r_al = sum(1 for o in outputs if at(o.rule_score,  o.job_code).decision == "ALERT")
    i_al = sum(1 for o in outputs if o.overall_decision == "ALERT")
    chg  = sum(1 for o in outputs if at(o.rule_score, o.job_code).decision != o.overall_decision)
    fpc  = sum(1 for o in outputs if o.fp_flag)
    print(f"  Total screened         : {n}")
    print(f"  Rule-only  ALERTS      : {r_al} ({r_al/max(n,1)*100:.0f}%)")
    print(f"  Integrated ALERTS      : {i_al} ({i_al/max(n,1)*100:.0f}%)")
    print(f"  Decisions changed      : {chg}")
    print(f"  Possible false pos [!] : {fpc}")
    print(bar)


# ── Model report (delegates to ml_engine/model.py cv_metrics) ────────────────

def print_model_report(model):
    """Print full ML accuracy report from AMLModel.cv_metrics."""
    m = model.cv_metrics
    if not m:
        print("  No metrics available (model not trained or insufficient data).")
        return

    bar = "=" * 65
    print(f"\n{bar}")
    print("  ML MODEL ACCURACY REPORT")
    print(bar)
    print(f"\n  Training data")
    print(f"    Total samples : {m['n_samples']}")
    print(f"    Positives     : {m['n_pos']}  (risk_label=1 records)")
    print(f"    Negatives     : {m['n_neg']}  (cross-mismatched non-match pairs)")
    print(f"    Evaluation    : 5-fold stratified cross-validation\n")

    print(f"  {'Metric':<32} {'Mean':>8}  {'Std':>8}")
    print(f"  {'-'*50}")
    print(f"  {'ROC-AUC':<32} {m['cv_roc_auc']:>8.4f}  +/-{m['cv_roc_std']:.4f}")
    print(f"  {'PR-AUC (avg precision)':<32} {m['cv_pr_auc']:>8.4f}")
    print(f"  {'F1 Score':<32} {m['cv_f1']:>8.4f}")
    print(f"  {'Precision':<32} {m['cv_precision']:>8.4f}")
    print(f"  {'Recall':<32} {m['cv_recall']:>8.4f}")
    print(f"\n  Train-set ROC-AUC : {m['train_auc']:.4f}  (upper bound only)")

    cm = m["cm"]
    tn, fp, fn, tp = cm[0][0], cm[0][1], cm[1][0], cm[1][1]
    total = tn + fp + fn + tp
    print(f"\n  Confusion Matrix (train set)")
    print(f"                    Predicted CLEAR   Predicted ALERT")
    print(f"  Actual CLEAR      {tn:>15}   {fp:>15}")
    print(f"  Actual ALERT      {fn:>15}   {tp:>15}")
    print(f"\n  Accuracy = {(tp+tn)/total:.4f}  |  FPR = {fp/(fp+tn+1e-9):.4f}  |  FDR = {fp/(tp+fp+1e-9):.4f}")

    print(f"\n  Classification Report\n")
    print(textwrap.indent(m["cls_report"], "  "))

    print("  Top 5 Feature Importances")
    top5 = sorted(m["feature_importances"].items(), key=lambda x: -x[1])[:5]
    for fname, fval in top5:
        print(f"    {fname:<32} {fval:.4f}  [{_bar(min(fval * 3, 1.0), 16)}]")

    roc = m["cv_roc_auc"]
    if   roc >= 0.95: msg = "Excellent — very reliable risk separation."
    elif roc >= 0.85: msg = "Good — model adds clear value on borderline cases."
    elif roc >= 0.70: msg = "Fair — model helps but rule score is still primary."
    else:             msg = "Weak — need more / better labelled training data."
    print(f"\n  Interpretation:  ROC-AUC {roc:.2f}: {msg}")
    print(f"\n  NOTE: Metrics are on synthetic data. See REAL_DATA_INTEGRATION.md.")
    print(f"\n{bar}\n")


